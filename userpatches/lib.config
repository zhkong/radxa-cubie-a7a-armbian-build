#!/bin/bash

# Armbian build system sources this file during compilation.
# Use custom_kernel_config hook to append required kernel options
# by directly modifying .config (avoids dependency on scripts/config).

custom_kernel_config() {
	display_alert "Enabling custom routing kernel configs" "userpatches" "info"

	local opts=(
		CONFIG_IP_ADVANCED_ROUTER
		CONFIG_IP_MULTIPLE_TABLES
		CONFIG_IPV6_MULTIPLE_TABLES
	)

	# This hook is called once before .config exists and once after it is copied into place.
	# Report the intended changes for Armbian's hash calculation in both phases, but only
	# edit .config during the second phase when the file is actually present.
	if declare -p kernel_config_modifying_hashes >/dev/null 2>&1; then
		for opt in "${opts[@]}"; do
			kernel_config_modifying_hashes+=("${opt}=y")
		done
	fi

	[[ -f .config ]] || return 0

	for opt in "${opts[@]}"; do
		if grep -q "^# ${opt} is not set" .config 2>/dev/null; then
			sed -i "s/^# ${opt} is not set/${opt}=y/" .config
		elif grep -q "^${opt}=" .config 2>/dev/null; then
			sed -i "s/^${opt}=.*/${opt}=y/" .config
		else
			echo "${opt}=y" >> .config
		fi
	done
}
