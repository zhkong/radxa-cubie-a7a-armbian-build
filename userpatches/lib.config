#!/bin/bash

# Armbian build system sources this file during compilation.
# Use custom_kernel_config to append required kernel options.

custom_kernel_config() {
	display_alert "Enabling custom routing kernel configs" "userpatches" "info"

	if type kernel_config_set_y &>/dev/null; then
		kernel_config_set_y CONFIG_IP_ADVANCED_ROUTER
		kernel_config_set_y CONFIG_IP_MULTIPLE_TABLES
		kernel_config_set_y CONFIG_IPV6_MULTIPLE_TABLES
	else
		# Fallback: write directly into .config
		for opt in CONFIG_IP_ADVANCED_ROUTER CONFIG_IP_MULTIPLE_TABLES CONFIG_IPV6_MULTIPLE_TABLES; do
			if grep -q "^# ${opt} is not set" .config 2>/dev/null; then
				sed -i "s/^# ${opt} is not set/${opt}=y/" .config
			elif ! grep -q "^${opt}=" .config 2>/dev/null; then
				echo "${opt}=y" >> .config
			fi
		done
	fi
}
